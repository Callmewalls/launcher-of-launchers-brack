# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=launcher_of_launchers
DB_USER=root
DB_PASSWORD=

# Server Configuration
PORT=3000
NODE_ENV=production

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=24h

# Steam Integration
STEAM_API_BASE_URL=https://api.steampowered.com
STEAM_API_KEY=
STEAM_API_TIMEOUT_MS=10000
STEAM_COMMUNITY_BASE_URL=https://steamcommunity.com
STEAM_OPENID_URL=https://steamcommunity.com/openid/login
STEAM_OPENID_REALM=http://localhost:3000
STEAM_OPENID_RETURN_URL=http://localhost:3000/api/launchers/steam/callback
STEAM_DEFAULT_LANGUAGE=spanish
STEAM_STORE_BASE_URL=https://store.steampowered.com
STEAM_USER_AGENT=launcher-of-launchers/1.0

# Google OAuth
GOOGLE_CLIENT_ID=

# Other Launcher APIs
EPIC_API_KEY=
GOG_API_KEY=

# Optional local override for Xbox app / Game Pass PC scan root
XBOX_INSTALL_PATH=
