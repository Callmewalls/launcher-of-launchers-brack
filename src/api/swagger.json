	"paths": {
		"/steam/{steamId}/owned-games": {
			"get": {
				"operationId": "GetOwnedGames",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SteamGamesResponse"
								}
							}
						}
					},
					"400": {
						"description": "SteamID inválido",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SteamErrorResponse"
								}
							}
						}
					},
					"503": {
						"description": "Steam API no configurada",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SteamErrorResponse"
								}
							}
						}
					}
				},
				"description": "Devuelve el listado de juegos en propiedad de un usuario de Steam.",
				"tags": [
					"Steam"
				],
				"security": [],
				"parameters": [
					{
						"description": "SteamID64 de 17 dígitos (ej: 76561198000000000)",
						"in": "path",
						"name": "steamId",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Incluir nombre e imágenes de cada juego (por defecto true)",
						"in": "query",
						"name": "includeAppInfo",
						"required": false,
						"schema": {
							"type": "boolean"
						}
					}
				]
			}
		},
		"/steam/{steamId}/player-summary": {
