		"/library/{userGameId}/icon": {
			"get": {
				"operationId": "GetIcon",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"image/png": {
								"schema": {
									"anyOf": [
										{
											"type": "string",
											"format": "byte"
										},
										{}
									]
								}
							}
						}
					},
					"404": {
						"description": "Ícono no disponible",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/LibraryErrorResponse"
								}
							}
						}
					}
				},
				"description": "Devuelve el ícono PNG embebido en el ejecutable local del juego.\r\n404 cuando el juego no está instalado o no tiene executablePath.\r\nCacheable 24 h — los íconos no cambian entre sincronizaciones.",
				"tags": [
					"Library"
				],
				"security": [
					{
						"jwt": []
					}
				],
				"parameters": [
					{
						"in": "path",
						"name": "userGameId",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				]
			}
		},
		"/library/{userGameId}/launch": {
			"post": {
				"operationId": "LaunchGame",
				"responses": {
					"200": {
