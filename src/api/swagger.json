					"Steam"
				],
				"security": [],
				"parameters": [
					{
						"description": "SteamID64 de 17 dígitos",
						"in": "path",
						"name": "steamId",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"description": "Número máximo de juegos a devolver (por defecto 10)",
