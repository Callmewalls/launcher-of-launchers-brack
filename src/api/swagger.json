								}
							}
						}
					},
					"404": {
						"description": "Juego no encontrado",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/LibraryErrorResponse"
								}
							}
						}
					}
				},
				"description": "Lanza un juego instalado.\r\nPrioridad: executablePath guardado → protocol URL del launcher → auto-descubrimiento del .exe.",
				"tags": [
					"Library"
				],
				"security": [
					{
						"jwt": []
					}
				],
				"parameters": [
					{
						"in": "path",
						"name": "userGameId",
