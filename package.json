{
  "name": "launcher_of_launchers_backend",
  "version": "1.0.0",
  "description": "Launcher of launchers",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsoa spec-and-routes && tsc && tsc-alias",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "node dist/index.js",
    "predev": "npm run copy-front && npm run tsoa",
    "dev": "nodemon",
    "tsoa": "tsoa spec-and-routes",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate-steam": "openapi-generator-cli generate -i https://raw.githubusercontent.com/ceva24/openapi-steamworks-web-api/main/dist/steamworks-web-api.json -g typescript-axios -o ./src/connectors/steam-api --additional-properties=withSeparateModelsAndApi=true,apiPackage=api,modelPackage=model,useSingleRequestParameter=true,supportsES6=true,typescriptThreePlus=true",
    "electron:run": "electron dist/electron/main.js",
    "electron:dev": "npm run build && npm run build:electron && electron dist/electron/main.js",
    "copy-front": "powershell -ExecutionPolicy Bypass -Command \"$src = '../launcher_of_launchers_front/dist/launcher-of-launchers-front/browser'; if (Test-Path $src) { if (Test-Path frontend) { Remove-Item frontend -Recurse -Force }; Copy-Item -Path $src -Destination frontend -Recurse } else { Write-Host 'Frontend dist no encontrado, omitiendo copia.' }\"",
    "dist:dir": "powershell -ExecutionPolicy Bypass -File ../build-desktop.ps1 -Target dir",
    "dist:portable": "powershell -ExecutionPolicy Bypass -File ../build-desktop.ps1 -Target portable",
    "dist:win": "powershell -ExecutionPolicy Bypass -File ../build-desktop.ps1 -Target win"
  },
  "dependencies": {
    "@openapitools/openapi-generator-cli": "2.31",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.10.3",
    "sequelize": "^6.37.8",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.5.5",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.launcher.launchers",
    "productName": "Launcher of Launchers",
    "protocols": [
      {
        "name": "Launcher of Launchers",
        "schemes": [
          "launcher-of-launchers"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sqlite3/**"
    ],
    "directories": {
      "output": "../dist-electron"
    },
    "files": [
      "dist/**/*",
      "frontend/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    }
  }
}
