{
  "entryFile": "src/app.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/api/controllers/**/*.ts"],
  "tsconfig": "tsconfig.json",
  "spec": {
    "outputDirectory": "src/api",
    "specVersion": 3,
    "name": "Launcher of Launchers API",
    "version": "1.0.0",
    "securityDefinitions": {
      "jwt": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "routes": {
    "routesDir": "src/api/routes",
    "authenticationModule": "src/api/middlewares/tsoa.auth.ts",
    "basePath": "/api"
  }
}